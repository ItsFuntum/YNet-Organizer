<!DOCTYPE html>
<html lang="en"></html>

<head>
<meta charset="UTF-8">
<meta name="viewport" 
  content="width=device-width, 
    initial-scale=1.0">
  <title>YNet Organizer</title>
</head>

<body>
  <h1 style="text-align:center; text-decoration: underline;">YNet Organizer</h1>
  <p style="text-align:center;">by Funtum</p>

  <h1 style="font-size: 64px; font-style: oblique;">Rooms</h1>
  <ul>
    <% rooms.forEach((room, index) => { %>
      <li>
        <h2>Room <%= index + 1 %>: <%= room.name %></h2>
        <p><strong>Address:</strong> <%= room.address %></p>
        <p><strong>Port:</strong> <%= room.port %></p>
        <p><strong>Description:</strong> <%= room.description %></p>
        <p><strong>Players:</strong> <%= room.players?.length || 0 %>/<%= room.maxPlayers %></p>

        <% if (room.players && room.players.length > 0) { %>
          <p><strong>Player Names:</strong></p>
          <ul>
            <% room.players.forEach(player => { %>
              <li style="color: lime; font-weight: bold;"><%= player.nickname || "Unknown Player" %></li>
            <% }); %>
          </ul>
        <% } else { %>
          <p style="color: red; font-weight: bold;">No players connected.</p>
        <% } %>

        <p><strong>Has Password:</strong> <%= room.hasPassword ? 'Yes' : 'No' %></p>
      </li>
    <% }); %>
  </ul>

  <style type="text/css" media="screen">
    body {
        background-color: rgb(0, 0, 0);
        color: white;
    }
</style>
</body>

</html>